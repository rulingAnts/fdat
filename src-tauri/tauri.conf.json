{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FDAT",
  "version": "3.0.0",
  "identifier": "io.github.rulingants.fdat",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "windows": [
      {
        "title": "Flex DiscourseChart Analysis Tool (FDAT)",
        "width": 1280,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "Seth Johnston",
    "category": "Productivity",
    "shortDescription": "Discourse Analysis Tool for FieldWorks exports",
    "license": "../LICENSE"
  }
}
